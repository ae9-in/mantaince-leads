# Database Configuration
PGHOST=database-1.cluster-c56mq42qi4nb.eu-north-1.rds.amazonaws.com
PGPORT=5432
PGUSER=postgres
PGDATABASE=postgres
PGPASSWORD=your_password
PGSSL=true

# AWS Configuration (Required for RDS IAM)
USE_RDS_IAM=true
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=your_session_token (Required if using temporary credentials)

# App Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
FRONTEND_URL=http://localhost:5173

# MongoDB (Optional/Legacy)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
