{
  "name": "leads-maintenance-root",
  "version": "1.0.0",
  "description": "Root runner for Leads Base Monorepo",
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch server/src --ext js,mjs,cjs,json server/src/app.js",
    "dev:worker": "nodemon --watch server/src --ext js,mjs,cjs,json server/src/jobs/worker.js",
    "dev:client": "npm run dev --prefix client",
    "seed": "node server/src/scripts/seed.js",
    "build": "npm run build --prefix client",
    "test:integration": "node server/src/testAllBackend.js",
    "test:unit": "vitest run tests/unit",
    "test:integration:api": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^8.2.2",
    "exifr": "^7.1.3",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
