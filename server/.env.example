PORT=4000
NODE_ENV=development
JWT_ACCESS_SECRET=change_me_32_chars_min_leadsbase_access
JWT_REFRESH_SECRET=change_me_32_chars_min_leadsbase_refresh_different
CLIENT_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=dummy_user
SMTP_PASS=dummy_pass
SMTP_FROM=noreply@leadsbase.io
MAX_CSV_FILE_SIZE_MB=10

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=your_session_token (Optional, required for temporary credentials)

# SQS Queue
SQS_IMPORT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your_account_id/your_queue_name

# S3 Bucket
S3_BUCKET=your_bucket_name

# SES
SES_FROM_EMAIL=noreply@yourdomain.com
