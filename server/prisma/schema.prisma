datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleName {
  super_admin
  vertical_admin
  agent
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  permissions String[] @default([])
  isSystem    Boolean  @default(true)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                   String            @id @default(uuid())
  name                 String
  email                String            @unique
  passwordHash         String
  roleId               String
  role                 Role              @relation(fields: [roleId], references: [id])
  isActive             Boolean           @default(true)
  lastLoginAt          DateTime?
  createdBy            String?
  creator              User?             @relation("UserToUser", fields: [createdBy], references: [id])
  createdUsers         User[]            @relation("UserToUser")
  inviteToken          String?
  inviteTokenExpiry    DateTime?
  verticalAccess       VerticalAccess[]
  assignedSubVerticals UserSubVertical[]
  costConversions      CostConversion[]  @relation("CostConversionsAssigned")
  uploadedCostConversions CostConversion[] @relation("CostConversionsUploaded")
  deletedCostConversions  CostConversion[] @relation("CostConversionsDeleted")
  csvUploadLogs        CsvUploadLog[]
  auditLogs            AuditLog[]
  sessions             Session[]
  userAssignments      UserAssignment[]  @relation("UserAssignments")
  createdAssignments   UserAssignment[]  @relation("AssignmentsCreated")
  verticalsCreated     Vertical[]
  subVerticalsCreated  SubVertical[]
  fieldConfigsCreated  FieldConfig[]
  assignedFollowUps    FollowUp[]        @relation("FollowUpAssignee")
  createdFollowUps     FollowUp[]        @relation("FollowUpCreator")
  escalationsCreated   Escalation[]      @relation("EscalatedBy")
  escalationsReceived  Escalation[]      @relation("EscalatedTo")
  escalationsResolved  Escalation[]      @relation("EscalationResolvedBy")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model VerticalAccess {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verticalId String
  vertical   Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@id([userId, verticalId])
}

model UserSubVertical {
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subVerticalId String
  subVertical   SubVertical @relation(fields: [subVerticalId], references: [id], onDelete: Cascade)

  @@id([userId, subVerticalId])
}

model Vertical {
  id             String           @id @default(uuid())
  name           String
  slug           String           @unique
  description    String?
  color          String           @default("#185FA5")
  icon           String           @default("Layers")
  isActive       Boolean          @default(true)
  displayOrder   Int              @default(0)
  createdBy      String?
  creator        User?            @relation(fields: [createdBy], references: [id])
  subVerticals   SubVertical[]
  fieldConfigs   FieldConfig[]
  costConversions CostConversion[]
  csvUploadLogs  CsvUploadLog[]
  verticalAccess VerticalAccess[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model SubVertical {
  id             String            @id @default(uuid())
  name           String
  slug           String
  verticalId     String
  vertical       Vertical          @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  isActive       Boolean           @default(true)
  displayOrder   Int               @default(0)
  createdBy      String?
  creator        User?             @relation(fields: [createdBy], references: [id])
  costConversions CostConversion[]
  userAccess     UserSubVertical[]
  users          UserAssignment[]
  customFields   CustomField[]
  followUps      FollowUp[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([verticalId, slug])
}

model FieldConfig {
  id                String   @id @default(uuid())
  verticalId        String
  vertical          Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  fieldKey          String
  label             String
  fieldType         String
  options           String[] @default([])
  placeholder       String   @default("")
  defaultValue      Json?
  isRequired        Boolean  @default(false)
  isVisible         Boolean  @default(true)
  isTableColumn     Boolean  @default(true)
  isCsvMapped       Boolean  @default(true)
  csvHeader         String   @default("")
  validationRegex   String   @default("")
  validationMessage String   @default("")
  displayOrder      Int      @default(0)
  createdBy         String?
  creator           User?    @relation(fields: [createdBy], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([verticalId, fieldKey])
}

model CostConversion {
  id            String       @id @default(uuid())
  name          String       @default("")
  phone         String       @default("")
  businessName  String       @default("")
  verticalId    String
  vertical      Vertical     @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  subVerticalId String?
  subVertical   SubVertical? @relation(fields: [subVerticalId], references: [id])
  assignedTo    String?
  assignedUser  User?        @relation("CostConversionsAssigned", fields: [assignedTo], references: [id])
  uploadedBy    String
  uploader      User         @relation("CostConversionsUploaded", fields: [uploadedBy], references: [id])
  data          Json         @default("{}")
  status        String       @default("new")
  source        String       @default("manual")
  csvBatchId    String?
  csvUploadLog  CsvUploadLog? @relation(fields: [csvBatchId], references: [id])
  isDeleted     Boolean      @default(false)
  deletedAt     DateTime?
  deletedBy     String?
  deletedByUser User?        @relation("CostConversionsDeleted", fields: [deletedBy], references: [id])
  leadType      CostConversionType @default(CALL)
  geotagLat     Float?
  geotagLng     Float?
  geotagAccuracy Float?
  geotagPhotoKey String?
  geotagAddress  String?
  geotagCapturedAt DateTime?
  customValues  CostConversionCustomValue[]
  followUps     FollowUp[]
  escalations   Escalation[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([subVerticalId, isDeleted, createdAt(sort: Desc)])
  @@index([verticalId, subVerticalId, isDeleted, createdAt(sort: Desc)])
}

model CsvUploadLog {
  id                    String    @id @default(uuid())
  uploadedBy            String
  uploader              User      @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  verticalId            String
  vertical              Vertical  @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  originalFileName      String
  totalRows             Int       @default(0)
  successCount          Int       @default(0)
  failedCount           Int       @default(0)
  duplicateCount        Int       @default(0)
  errors                Json      @default("[]")
  status                String    @default("queued")
  processingStartedAt   DateTime?
  processingFinishedAt  DateTime?
  failedRowsDownloadUrl String    @default("")
  costConversions       CostConversion[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model AuditLog {
  id               String   @id @default(uuid())
  actorId          String
  actor            User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  actorEmail       String
  action           String
  targetCollection String
  targetId         String
  before           Json?
  after            Json?
  ip               String   @default("")
  userAgent        String   @default("")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  ip        String   @default("")
  userAgent String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAssignment {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)
  subVerticalId String
  subVertical   SubVertical @relation(fields: [subVerticalId], references: [id], onDelete: Cascade)
  assignedBy    String
  assigner      User        @relation("AssignmentsCreated", fields: [assignedBy], references: [id])
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, subVerticalId])
}

// ─────────────────────────────────────────────────────────────────────────────
// F3 — CUSTOM FIELDS PER SUB-VERTICAL
// ─────────────────────────────────────────────────────────────────────────────

model CustomField {
  id            String          @id @default(cuid())
  subVerticalId String
  label         String          // display label: "GST Number"
  fieldKey      String          // snake_case key: "gst_number"
  fieldType     CustomFieldType @default(TEXT)
  isRequired    Boolean         @default(false)
  placeholder   String?
  options       String[]        // for SELECT type: ["Option A", "Option B"]
  order         Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())

  subVertical    SubVertical         @relation(fields: [subVerticalId], references: [id], onDelete: Cascade)
  leadFieldValues CostConversionCustomValue[]

  @@unique([subVerticalId, fieldKey])
  @@index([subVerticalId, isActive, order])
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  TEXTAREA
  PHONE
  EMAIL
  URL
}

model CostConversionCustomValue {
  id               String @id @default(cuid())
  costConversionId String
  customFieldId    String
  value            String

  costConversion CostConversion @relation(fields: [costConversionId], references: [id], onDelete: Cascade)
  customField    CustomField    @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([costConversionId, customFieldId])
  @@index([costConversionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// F4 — LEAD TYPE + GEOTAG
// ─────────────────────────────────────────────────────────────────────────────

enum CostConversionType {
  CALL
  FIELD_VISIT
}

// ─────────────────────────────────────────────────────────────────────────────
// F5 — FOLLOW-UPS
// ─────────────────────────────────────────────────────────────────────────────

model FollowUp {
  id            String       @id @default(cuid())
  costConversionId String
  subVerticalId String
  assignedToId  String       // employee (User) assigned to follow up
  createdById   String       // who created this follow-up
  followUpDate  DateTime     // scheduled date+time of follow-up
  description   String       // what happened / what to do
  status        FollowUpStatus @default(PENDING)
  completedAt   DateTime?
  completedNote String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  costConversion CostConversion @relation(fields: [costConversionId], references: [id], onDelete: Cascade)
  assignedTo  User  @relation("FollowUpAssignee", fields: [assignedToId], references: [id])
  createdBy   User  @relation("FollowUpCreator", fields: [createdById], references: [id])
  subVertical SubVertical @relation(fields: [subVerticalId], references: [id])

  @@index([costConversionId, followUpDate])
  @@index([subVerticalId, followUpDate])       // calendar grid query
  @@index([assignedToId, status, followUpDate]) // "my follow-ups" view
  @@index([followUpDate])                       // date-range queries
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
  RESCHEDULED
}

// ─────────────────────────────────────────────────────────────────────────────
// F7 — ESCALATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Escalation {
  id               String   @id @default(cuid())
  costConversionId String
  escalatedById    String
  escalatedToId    String
  reason           String
  status           EscalationStatus @default(OPEN)
  resolutionNote   String?
  resolvedById     String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  costConversion   CostConversion @relation(fields: [costConversionId], references: [id], onDelete: Cascade)
  escalatedBy      User @relation("EscalatedBy",  fields: [escalatedById], references: [id])
  escalatedTo      User @relation("EscalatedTo",  fields: [escalatedToId], references: [id])
  resolvedBy       User? @relation("EscalationResolvedBy", fields: [resolvedById], references: [id])

  @@index([costConversionId, status, createdAt(sort: Desc)])
  @@index([escalatedToId, status])
  @@index([escalatedById, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

enum EscalationStatus {
  OPEN
  RESOLVED
  REJECTED
}
